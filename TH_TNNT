def tbc_chan_dong_le(a):
    s = 0
    count = 0

    for i in range(len(a)):
        if i % 2 == 1:  # dòng lẻ
            for j in range(len(a[0])):
                if a[i][j] % 2 == 0:
                    s += a[i][j]
                    count += 1

    return s / count if count > 0 else 0
