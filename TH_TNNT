def cot_tich_nho_nhat(a):
    m = len(a)
    n = len(a[0])

    min_tich = float('inf')
    index = -1

    for j in range(n):
        tich = 1
        for i in range(m):
            tich *= a[i][j]

        if tich < min_tich:
            min_tich = tich
            index = j

    return index
